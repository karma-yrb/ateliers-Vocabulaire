/* â”€â”€â”€ Utils â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */

function norm(s) {
  return (s || '').toLowerCase().trim()
    .normalize('NFD').replace(/[\u0300-\u036f]/g, '');
}

function shuffle(arr) {
  const a = [...arr];
  for (let i = a.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [a[i], a[j]] = [a[j], a[i]];
  }
  return a;
}

function stripArticle(s) {
  return s.replace(/^(un|une|du|de la|des|le|la|les)\s+/i, '').toLowerCase().trim();
}

/* â”€â”€â”€ Navigation â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */

function goHome() {
  document.getElementById('screen-welcome').style.display = 'flex';
  document.getElementById('screen-alpha').classList.remove('active');
  document.getElementById('screen-allophone').classList.remove('active');
  alloStopTimer();
}

function startLevel(level) {
  document.getElementById('screen-welcome').style.display = 'none';
  if (level === 'alpha') {
    aSource = VOCAB_ALPHA;
    document.getElementById('screen-alpha').classList.add('active');
    alphaInit();
  } else if (level === 'numerique') {
    aSource = VOCAB_NUMERIQUE;
    document.getElementById('screen-alpha').classList.add('active');
    alphaInit();
  } else {
    document.getElementById('screen-allophone').classList.add('active');
    alloInit();
  }
}

/* â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
   ALPHA ENGINE
   â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• */

let aDeck      = [];
let aSource    = VOCAB_ALPHA;
let aIdx       = 0;
let aCorrect   = 0;
let aAnswered  = false;
let aMode      = 'scramble';
let aPool      = [];   // letter pool
let aTyped     = [];   // typed chars
let aTarget    = [];   // target chars (spaces included)
let aNextTimer = null; // pending auto-advance timer

function alphaInit() {
  aDeck    = shuffle(aSource);
  aIdx     = 0;
  aCorrect = 0;
  document.getElementById('alpha-completed').classList.remove('show');
  document.getElementById('alpha-card').style.display = 'flex';
  alphaLoad();
}

function alphaRestart() { alphaInit(); }

function alphaLoad() {
  aAnswered = false;
  const w = aDeck[aIdx];

  // Emoji
  const em = document.getElementById('alpha-emoji');
  em.style.animation = 'none';
  void em.offsetWidth;
  em.style.animation = '';
  if (w.img) {
    em.classList.add('has-image');
    em.innerHTML = `<img class="alpha-emoji-img" src="${w.img}" alt="${w.word}">`;
  } else {
    em.classList.remove('has-image');
    em.textContent = w.emoji;
  }

  document.getElementById('alpha-cat').textContent = w.cat;

  const total = aDeck.length;
  document.getElementById('alpha-counter').textContent = `${aIdx + 1} / ${total}`;
  document.getElementById('alpha-bar').style.width = `${((aIdx + 1) / total) * 100}%`;

  if (aMode === 'scramble') {
    alphaSetupScramble(w);
  } else {
    document.getElementById('alpha-view-word').textContent = w.word;
  }

  document.getElementById('alpha-feedback').textContent = '';
  document.getElementById('alpha-feedback').className = 'feedback-msg';
}

function alphaSetupScramble(w) {
  aTarget = [...w.word];
  const letters = aTarget.filter(c => c !== ' ');
  aTyped = aTarget.map(c => (c === ' ' ? ' ' : ''));
  aPool  = shuffle(letters).map((l, i) => ({ l, uid: i, used: false }));
  renderAChars();
  renderALetters();
}

function renderAChars() {
  const c = document.getElementById('alpha-char-boxes');
  c.innerHTML = '';
  aTyped.forEach((ch, i) => {
    const box = document.createElement('div');
    if (ch === ' ') {
      box.className = 'char-box space';
      box.textContent = ' ';
    } else {
      box.className = 'char-box ' + (ch ? 'filled' : 'empty');
      box.textContent = ch ? ch : '  ';
      if (ch) box.onclick = () => aRemoveChar(i);
    }
    c.appendChild(box);
  });
}

function renderALetters() {
  const c = document.getElementById('alpha-letter-bank');
  c.innerHTML = '';
  aPool.forEach(item => {
    const btn = document.createElement('button');
    btn.className = 'letter-tile' + (item.used ? ' used' : '');
    btn.textContent = item.l;
    btn.onclick = () => aAddLetter(item);
    c.appendChild(btn);
  });
}

function aAddLetter(item) {
  if (aAnswered || item.used) return;
  const next = aTyped.indexOf('');
  if (next === -1) return;
  item.used = true;
  aTyped[next] = item.l;
  renderAChars();
  renderALetters();
  if (!aTyped.includes('')) aCheckScramble();
}

function aRemoveChar(i) {
  if (aAnswered) return;
  const letter = aTyped[i];
  aTyped[i] = '';
  const pi = aPool.find(p => p.used && p.l === letter);
  if (pi) pi.used = false;
  renderAChars();
  renderALetters();
}

function aCheckScramble() {
  const w   = aDeck[aIdx];
  const ans = aTyped.join('');
  const ok  = norm(ans) === norm(w.word);
  const fb  = document.getElementById('alpha-feedback');

  if (ok) {
    fb.textContent = 'âœ“ ' + w.word;
    fb.className   = 'feedback-msg ok';
    aCorrect++;
    aAnswered = true;
    const btn = document.getElementById('alpha-next-btn');
    if (btn) btn.disabled = true;
    aNextTimer = setTimeout(alphaNextWord, 1300);
  } else {
    fb.textContent = 'âœ— Essayez encoreâ€¦';
    fb.className   = 'feedback-msg ko';
    setTimeout(() => {
      aTyped = aTarget.map(c => (c === ' ' ? ' ' : ''));
      aPool.forEach(p => p.used = false);
      renderAChars();
      renderALetters();
      fb.textContent = '';
      fb.className   = 'feedback-msg';
    }, 900);
  }
}

function alphaReset() {
  if (aMode !== 'scramble') return;
  aTyped = aTarget.map(c => (c === ' ' ? ' ' : ''));
  aPool.forEach(p => p.used = false);
  renderAChars();
  renderALetters();
  document.getElementById('alpha-feedback').textContent = '';
  document.getElementById('alpha-feedback').className   = 'feedback-msg';
}

function alphaNextWord() {
  if (aNextTimer) { clearTimeout(aNextTimer); aNextTimer = null; }
  const btn = document.getElementById('alpha-next-btn');
  if (btn) btn.disabled = false;
  if (aIdx < aDeck.length - 1) {
    aIdx++;
    alphaLoad();
  } else {
    alphaShowCompleted();
  }
}

function alphaPrevWord() {
  if (aIdx > 0) { aIdx--; alphaLoad(); }
}

function alphaShowCompleted() {
  document.getElementById('alpha-card').style.display = 'none';
  const comp = document.getElementById('alpha-completed');
  comp.classList.add('show');
  const pct = Math.round((aCorrect / aDeck.length) * 100);
  document.getElementById('alpha-pct').textContent = pct + ' %';
  document.getElementById('alpha-sub').textContent =
    `${aCorrect} bonne${aCorrect !== 1 ? 's' : ''} rÃ©ponse${aCorrect !== 1 ? 's' : ''} sur ${aDeck.length} mots`;
}

function setAlphaMode(m) {
  aMode = m;
  const isSc = m === 'scramble';
  document.getElementById('alpha-scramble').style.display = isSc  ? 'flex' : 'none';
  document.getElementById('alpha-view').style.display     = !isSc ? 'flex' : 'none';
  document.getElementById('alpha-btn-scramble').classList.toggle('active', isSc);
  document.getElementById('alpha-btn-view').classList.toggle('active', !isSc);
  alphaLoad();
}

/* â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
   ALLOPHONE ENGINE
   â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• */

let oVocab     = [];   // filtered vocab
let oDeck      = [];   // current ordered deck
let oIdx       = 0;
let oCorrect   = 0;
let oWrong     = 0;
let oTries     = 0;
let oAnswered  = false;
let oMode      = 'ecrire';
let oActiveCat = new Set();
let oTimerId   = null;
let oSecs      = 0;
let oPool      = [];
let oTyped     = [];
let oTarget    = [];   // target chars (spaces included)

function alloInit() {
  const cats = [...new Set(VOCAB_ALLOPHONE.map(w => w.cat))];
  oActiveCat = new Set(cats);
  oCorrect = 0; oWrong = 0; oTries = 0;
  buildCatFilter(cats);
  alloUpdateStats();
  alloBuildDeck();
  setAlloMode('ecrire');
  document.getElementById('allo-completed').classList.remove('show');
  document.getElementById('allo-card').style.display = 'flex';
}

function alloBuildDeck() {
  oVocab = VOCAB_ALLOPHONE.filter(w => oActiveCat.has(w.cat));
  oDeck  = shuffle(oVocab);
  oIdx   = 0;
  oAnswered = false;
  alloUpdateProgress();
  if (oDeck.length > 0) alloLoad();
}

function buildCatFilter(cats) {
  const c = document.getElementById('allo-cats');
  c.innerHTML = '';
  cats.forEach(cat => {
    const n    = VOCAB_ALLOPHONE.filter(w => w.cat === cat).length;
    const pill = document.createElement('button');
    pill.className    = 'cat-pill active';
    pill.dataset.cat  = cat;
    pill.innerHTML    = `<span>${cat}</span><span class="cat-count">${n}</span>`;
    pill.onclick      = () => toggleCat(cat, pill);
    c.appendChild(pill);
  });
}

function toggleCat(cat, pill) {
  if (oActiveCat.has(cat)) {
    if (oActiveCat.size === 1) return;
    oActiveCat.delete(cat);
    pill.classList.remove('active');
  } else {
    oActiveCat.add(cat);
    pill.classList.add('active');
  }
  alloBuildDeck();
}

function alloLoad() {
  oAnswered = false;
  const w = oDeck[oIdx];

  const em = document.getElementById('allo-emoji');
  em.style.animation = 'none';
  void em.offsetWidth;
  em.style.animation = '';
  em.textContent = w.emoji;

  document.getElementById('allo-cat').textContent = w.cat;
  alloUpdateProgress();
  alloClearFeedback();

  document.getElementById('allo-check-btn').textContent = 'VÃ©rifier';

  if (oMode === 'ecrire') {
    const inp = document.getElementById('allo-input');
    inp.value     = '';
    inp.className = 'write-input';
    inp.focus();
  } else if (oMode === 'qcm') {
    alloSetupQCM(w);
  } else if (oMode === 'lettres') {
    alloSetupLettres(w);
  } else {
    document.getElementById('allo-view-word').textContent = w.word;
  }
}

function alloClearFeedback() {
  ['allo-fb-write', 'allo-fb-qcm', 'allo-fb-lettres'].forEach(id => {
    const el = document.getElementById(id);
    el.textContent = '';
    el.className   = 'feedback-msg';
  });
}

function alloUpdateProgress() {
  const total = oDeck.length;
  const cur   = Math.min(oIdx + 1, total);
  document.getElementById('allo-prog-label').textContent = `${cur} / ${total}`;
  document.getElementById('allo-word-num').textContent   = `Mot ${cur} / ${total}`;
  document.getElementById('allo-bar').style.width = `${total ? (cur / total) * 100 : 0}%`;
}

function alloUpdateStats() {
  document.getElementById('s-ok').textContent  = oCorrect;
  document.getElementById('s-ko').textContent  = oWrong;
  document.getElementById('s-try').textContent = oTries;
  document.getElementById('s-pct').textContent =
    oTries > 0 ? Math.round((oCorrect / oTries) * 100) + ' %' : 'â€”';
}

/* Write mode */
function alloCheck() {
  if (oAnswered) { alloNext(); return; }

  const w   = oDeck[oIdx];
  const inp = document.getElementById('allo-input');
  const val = inp.value.trim();

  if (!val) {
    const fb = document.getElementById('allo-fb-write');
    fb.textContent = 'Entrez un mot avant de valider.';
    fb.className   = 'feedback-msg ko';
    return;
  }

  const nVal     = norm(val);
  const targets  = [norm(w.word), norm(stripArticle(w.word))];
  const ok       = targets.some(t => nVal === t);

  oTries++;
  const fb = document.getElementById('allo-fb-write');

  if (ok) {
    inp.className  = 'write-input correct';
    fb.textContent = 'âœ“ Correct â€” ' + w.word;
    fb.className   = 'feedback-msg ok';
    oCorrect++;
  } else {
    inp.className  = 'write-input wrong';
    fb.textContent = `âœ— RÃ©ponse attendue : ${w.word}`;
    fb.className   = 'feedback-msg ko';
    oWrong++;
  }

  oAnswered = true;
  alloUpdateStats();
  document.getElementById('allo-check-btn').textContent = 'Mot suivant â†’';
}

/* QCM mode */
function alloSetupQCM(w) {
  const grid  = document.getElementById('allo-qcm-grid');
  grid.innerHTML = '';

  // Pick 3 distractors from full bank (never the correct word)
  const pool  = VOCAB_ALLOPHONE.filter(v => norm(v.word) !== norm(w.word));
  const opts  = shuffle([w, ...shuffle(pool).slice(0, 3)]);

  opts.forEach(opt => {
    const btn  = document.createElement('button');
    btn.className = 'qcm-opt';
    btn.textContent = stripArticle(opt.word);
    btn.onclick = () => alloQCMPick(opt, w, grid);
    grid.appendChild(btn);
  });
}

function alloQCMPick(chosen, correct, grid) {
  if (oAnswered) return;
  oAnswered = true;
  oTries++;

  const isOk = norm(chosen.word) === norm(correct.word);
  const fb   = document.getElementById('allo-fb-qcm');

  grid.querySelectorAll('.qcm-opt').forEach(btn => {
    const t = norm(btn.textContent);
    if (t === norm(stripArticle(correct.word)))  btn.classList.add('reveal');
    else if (t === norm(stripArticle(chosen.word)) && !isOk) btn.classList.add('wrong');
    else btn.classList.add('disabled');
    btn.style.pointerEvents = 'none';
  });

  if (isOk) {
    fb.textContent = 'âœ“ Correct â€” ' + correct.word;
    fb.className   = 'feedback-msg ok';
    oCorrect++;
  } else {
    fb.textContent = `âœ— RÃ©ponse attendue : ${correct.word}`;
    fb.className   = 'feedback-msg ko';
    oWrong++;
  }

  alloUpdateStats();
}

/* Lettres mode */
function alloSetupLettres(w) {
  document.getElementById('allo-fb-lettres').textContent = '';
  document.getElementById('allo-fb-lettres').className   = 'feedback-msg';

  const clean  = stripArticle(w.word);
  oTarget = [...clean];
  const letters = oTarget.filter(c => c !== ' ');
  oTyped = oTarget.map(c => (c === ' ' ? ' ' : ''));
  oPool  = shuffle(letters).map((l, i) => ({ l, uid: i, used: false }));

  renderOChars();
  renderOLetters();
}

function renderOChars() {
  const c = document.getElementById('allo-char-boxes');
  c.innerHTML = '';
  oTyped.forEach((ch, i) => {
    const box = document.createElement('div');
    if (ch === ' ') {
      box.className = 'char-box space';
      box.textContent = ' ';
    } else {
      box.className = 'char-box ' + (ch ? 'filled' : 'empty');
      box.textContent = ch ? ch : '  ';
      if (ch) box.onclick = () => oRemoveChar(i);
    }
    c.appendChild(box);
  });
}

function renderOLetters() {
  const c = document.getElementById('allo-letter-bank');
  c.innerHTML = '';
  oPool.forEach(item => {
    const btn = document.createElement('button');
    btn.className = 'letter-tile' + (item.used ? ' used' : '');
    btn.textContent = item.l;
    btn.onclick = () => oAddLetter(item);
    c.appendChild(btn);
  });
}

function oAddLetter(item) {
  if (oAnswered || item.used) return;
  const next = oTyped.indexOf('');
  if (next === -1) return;
  item.used = true;
  oTyped[next] = item.l;
  renderOChars();
  renderOLetters();
  if (!oTyped.includes('')) alloCheckLettres();
}

function oRemoveChar(i) {
  if (oAnswered) return;
  const letter = oTyped[i];
  oTyped[i] = '';
  const pi = oPool.find(p => p.used && p.l === letter);
  if (pi) pi.used = false;
  renderOChars();
  renderOLetters();
}

function alloLettersReset() {
  oTyped = oTarget.map(c => (c === ' ' ? ' ' : ''));
  oPool.forEach(p => p.used = false);
  renderOChars();
  renderOLetters();
  document.getElementById('allo-fb-lettres').textContent = '';
  document.getElementById('allo-fb-lettres').className   = 'feedback-msg';
}

function alloCheckLettres() {
  const w     = oDeck[oIdx];
  const clean = stripArticle(w.word);
  const ans   = oTyped.join('');
  const ok    = norm(ans) === norm(clean);

  oTries++;
  const fb = document.getElementById('allo-fb-lettres');

  if (ok) {
    fb.textContent = 'âœ“ Correct â€” ' + w.word;
    fb.className   = 'feedback-msg ok';
    oCorrect++;
    oAnswered = true;
    alloUpdateStats();
    setTimeout(alloNext, 1300);
  } else {
    fb.textContent = 'âœ— Essayez encoreâ€¦';
    fb.className   = 'feedback-msg ko';
    oWrong++;
    alloUpdateStats();
    setTimeout(() => {
      oTyped = oTarget.map(c => (c === ' ' ? ' ' : ''));
      oPool.forEach(p => p.used = false);
      renderOChars();
      renderOLetters();
      fb.textContent = '';
      fb.className   = 'feedback-msg';
    }, 900);
  }
}

/* Navigation */
function alloNext() {
  if (oIdx < oDeck.length - 1) {
    oIdx++;
    alloLoad();
  } else {
    alloShowCompleted();
  }
}

function alloPrev() {
  if (oIdx > 0) { oIdx--; alloLoad(); }
}

function alloShuffle() {
  oDeck = shuffle(oDeck);
  oIdx  = 0;
  alloLoad();
}

function alloNewSeries() {
  oCorrect = 0; oWrong = 0; oTries = 0;
  alloUpdateStats();
  document.getElementById('allo-card').style.display = 'flex';
  document.getElementById('allo-completed').classList.remove('show');
  alloBuildDeck();
}

function alloRestart() {
  document.getElementById('allo-card').style.display = 'flex';
  document.getElementById('allo-completed').classList.remove('show');
  oCorrect = 0; oWrong = 0; oTries = 0;
  alloUpdateStats();
  alloBuildDeck();
}

function alloShowCompleted() {
  document.getElementById('allo-card').style.display = 'none';
  const comp = document.getElementById('allo-completed');
  comp.classList.add('show');
  const pct = oTries > 0 ? Math.round((oCorrect / oTries) * 100) : 0;
  document.getElementById('allo-pct').textContent = pct + ' %';
  document.getElementById('allo-sub').textContent =
    `${oCorrect} bonne${oCorrect !== 1 ? 's' : ''} rÃ©ponse${oCorrect !== 1 ? 's' : ''} sur ${oTries} tentative${oTries !== 1 ? 's' : ''}`;
}

/* Mode switching */
function setAlloMode(m) {
  oMode = m;
  ['ecrire', 'qcm', 'lettres', 'voir'].forEach(id => {
    document.getElementById('allo-m-' + id).style.display = (id === m) ? 'flex' : 'none';
    document.getElementById('tab-' + id).classList.toggle('active', id === m);
  });
  if (oDeck.length > 0) alloLoad();
}

/* Timer */
function alloStartTimer(minutes) {
  alloStopTimer();
  oSecs = minutes * 60;
  renderTimer();
  oTimerId = setInterval(() => {
    oSecs--;
    renderTimer();
    if (oSecs <= 0) {
      alloStopTimer();
      const el = document.getElementById('allo-timer');
      el.textContent = 'Temps Ã©coulÃ©';
      el.style.color = 'var(--ko)';
    }
  }, 1000);
}

function alloStopTimer() {
  if (oTimerId) { clearInterval(oTimerId); oTimerId = null; }
  document.getElementById('allo-timer').style.color = '';
}

function renderTimer() {
  const m = Math.floor(oSecs / 60).toString().padStart(2, '0');
  const s = (oSecs % 60).toString().padStart(2, '0');
  document.getElementById('allo-timer').textContent = m + ':' + s;
}

/* Keyboard shortcuts */
function isEditableTarget(el) {
  if (!el) return false;
  const tag = (el.tagName || '').toLowerCase();
  return el.isContentEditable || tag === 'input' || tag === 'textarea' || tag === 'select';
}

function findUnusedPoolItem(pool, keyChar) {
  const nk = norm(keyChar);
  return pool.find(item => !item.used && norm(item.l) === nk);
}

function alphaAddLetterFromKey(key) {
  if (aMode !== 'scramble' || aAnswered) return false;
  if (!key || key.length !== 1 || /\s/.test(key)) return false;
  const item = findUnusedPoolItem(aPool, key.toLowerCase());
  if (!item) return false;
  aAddLetter(item);
  return true;
}

function alphaRemoveLastLetter() {
  if (aMode !== 'scramble' || aAnswered) return false;
  for (let i = aTyped.length - 1; i >= 0; i--) {
    if (aTyped[i] && aTyped[i] !== ' ') {
      aRemoveChar(i);
      return true;
    }
  }
  return false;
}

function alloAddLetterFromKey(key) {
  if (oMode !== 'lettres' || oAnswered) return false;
  if (!key || key.length !== 1 || /\s/.test(key)) return false;
  const item = findUnusedPoolItem(oPool, key.toLowerCase());
  if (!item) return false;
  oAddLetter(item);
  return true;
}

function alloRemoveLastLetter() {
  if (oMode !== 'lettres' || oAnswered) return false;
  for (let i = oTyped.length - 1; i >= 0; i--) {
    if (oTyped[i] && oTyped[i] !== ' ') {
      oRemoveChar(i);
      return true;
    }
  }
  return false;
}

function alloPickQCMByDigit(digit) {
  if (oMode !== 'qcm' || oAnswered) return false;
  const idx = Number(digit) - 1;
  const opts = [...document.querySelectorAll('#allo-qcm-grid .qcm-opt')];
  if (idx < 0 || idx >= opts.length) return false;
  opts[idx].click();
  return true;
}

document.addEventListener('keydown', e => {
  if (e.ctrlKey || e.metaKey || e.altKey) return;

  const key = e.key;
  const editable = isEditableTarget(e.target);

  // Welcome: 1 alpha, 2 numerique, 3 allophone
  if (document.getElementById('screen-welcome').style.display !== 'none' && !editable) {
    if (key === '1') { e.preventDefault(); startLevel('alpha'); return; }
    if (key === '2') { e.preventDefault(); startLevel('numerique'); return; }
    if (key === '3') { e.preventDefault(); startLevel('allophone'); return; }
  }

  // Alpha + Numerique (same engine)
  if (document.getElementById('screen-alpha').classList.contains('active')) {
    if (key === 'ArrowRight') { e.preventDefault(); alphaNextWord(); return; }
    if (key === 'ArrowLeft')  { e.preventDefault(); alphaPrevWord(); return; }
    if (key === 'Enter' && (aMode === 'view' || aAnswered)) { e.preventDefault(); alphaNextWord(); return; }
    if ((key === 'Backspace' || key === 'Delete') && alphaRemoveLastLetter()) { e.preventDefault(); return; }
    if (alphaAddLetterFromKey(key)) { e.preventDefault(); return; }
  }

  // Allophone
  if (document.getElementById('screen-allophone').classList.contains('active')) {
    if (key === 'Enter' && oMode === 'ecrire') { e.preventDefault(); alloCheck(); return; }

    if (!editable && key === 'ArrowRight') { e.preventDefault(); alloNext(); return; }
    if (!editable && key === 'ArrowLeft')  { e.preventDefault(); alloPrev(); return; }

    if (!editable && alloPickQCMByDigit(key)) { e.preventDefault(); return; }

    if (!editable && oMode === 'lettres') {
      if ((key === 'Backspace' || key === 'Delete') && alloRemoveLastLetter()) { e.preventDefault(); return; }
      if (key === 'Enter' && oAnswered) { e.preventDefault(); alloNext(); return; }
      if (alloAddLetterFromKey(key)) { e.preventDefault(); return; }
    }

    if (!editable && oMode === 'voir' && key === 'Enter') {
      e.preventDefault();
      alloNext();
      return;
    }
  }
});
</script>
</body>
</html>


