        <div class="progress-fill allo-fill" id="allo-bar" style="width:0%"></div>
      </div>
      <div style="font-size:0.82rem;color:var(--muted);text-align:center;" id="allo-prog-label">0 / 0</div>
      <div class="stat-grid">
        <div class="stat-box ok"><div class="sv" id="s-ok">0</div><div class="sl">Correct</div></div>
        <div class="stat-box ko"><div class="sv" id="s-ko">0</div><div class="sl">Erreurs</div></div>
        <div class="stat-box nt"><div class="sv" id="s-try">0</div><div class="sl">Tentatives</div></div>
        <div class="stat-box">   <div class="sv" id="s-pct">â€”</div><div class="sl">RÃ©ussite</div></div>
      </div>
    </div>

    <!-- Mode tabs -->
    <div class="s-section">
      <div class="s-section-title">Mode d'exercice</div>
      <div class="mode-tabs">
        <button class="mode-tab active" id="tab-ecrire"  onclick="setAlloMode('ecrire')">âœï¸ Ã‰crire</button>
        <button class="mode-tab"        id="tab-qcm"     onclick="setAlloMode('qcm')">ðŸ”˜ QCM</button>
