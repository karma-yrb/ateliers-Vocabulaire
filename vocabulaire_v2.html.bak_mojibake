      <div class="allo-timer-display" id="allo-timer">00:00</div>
      <div class="allo-timer-btns">
        <button class="timer-btn teal"  onclick="alloStartTimer(30)">30 min</button>
        <button class="timer-btn teal"  onclick="alloStartTimer(60)">60 min</button>
        <button class="timer-btn ghost" onclick="alloStopTimer()">Stop</button>
