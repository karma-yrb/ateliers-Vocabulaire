      </div>
      <div class="allo-emoji-wrap">
        <div id="allo-emoji" class="allo-emoji">ðŸŽ</div>
      </div>

      <!-- Mode: Ã‰crire -->
      <div class="mode-area" id="allo-m-ecrire">
        <p class="mode-hint">Ã‰crivez le mot correspondant Ã  l'image (article inclus si possible)</p>
        <div class="write-row">
          <input class="write-input" id="allo-input" type="text"
            placeholder="Votre rÃ©ponseâ€¦" autocomplete="off" autocorrect="off" spellcheck="false">
          <button class="check-btn" id="allo-check-btn" onclick="alloCheck()">VÃ©rifier</button>
        </div>
        <div class="feedback-msg" id="allo-fb-write"></div>
      </div>

      <!-- Mode: QCM -->
