      <button class="btn btn-ghost"  onclick="alloNewSeries()">â‡„ Nouvelle sÃ©rie</button>
    </div>
  </aside>

  <!-- â”€â”€ Main â”€â”€ -->
  <main class="allo-main">

    <!-- Exercise card -->
    <div class="allo-card" id="allo-card">
