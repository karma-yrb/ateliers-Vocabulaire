        <div class="feedback-msg" id="allo-fb-lettres"></div>
        <button class="btn btn-ghost" style="font-size:0.85rem;" onclick="alloLettersReset()">RÃ©initialiser</button>
      </div>

      <!-- Mode: Voir -->
      <div class="mode-area" id="allo-m-voir" style="display:none;">
        <p class="mode-hint">Lisez et mÃ©morisez ce mot</p>
        <div class="allo-view-word" id="allo-view-word">â€”</div>
        <p style="font-size:0.82rem;color:var(--muted);">Utilisez les flÃ¨ches du clavier ou les boutons ci-dessous</p>
      </div>

      <!-- Navigation -->
      <div class="allo-nav">
        <button class="nav-btn" onclick="alloPrev()">â† PrÃ©cÃ©dent</button>
        <button class="nav-btn icon" onclick="alloShuffle()" title="MÃ©langer la sÃ©rie">â‡„</button>
        <button class="nav-btn primary" onclick="alloNext()">Suivant â†’</button>
      </div>
    </div>

    <!-- Completed (allophone) -->
    <div class="completed-panel" id="allo-completed" style="max-width:640px;width:100%;">
      <div class="cp-emoji">ðŸŽ‰</div>
      <h2 style="color:var(--teal);">SÃ©rie terminÃ©e !</h2>
      <div class="cp-pct" id="allo-pct" style="color:var(--ok);">â€”</div>
      <p class="cp-sub" id="allo-sub"></p>
      <div style="display:flex;gap:10px;flex-wrap:wrap;justify-content:center;">
        <button class="btn btn-teal"  onclick="alloRestart()">Recommencer cette sÃ©rie</button>
        <button class="btn btn-ghost" onclick="goHome()">Changer de parcours</button>
      </div>
    </div>
  </main>

</div>


